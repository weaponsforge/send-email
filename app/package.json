{
  "name": "@weaponsforge/sendemail",
  "version": "1.2.2",
  "description": "Sends emails using Gmail SMTP with username/pw or Google OAuth2",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "sendemail": "./dist/scripts/cli/send.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/demo",
    "!dist/scripts/build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vitest",
    "transpile": "tsc -p tsconfig.prod.json && tsc-alias && npm run copy:files",
    "transpile:noemit": "tsc -p tsconfig.json --noEmit",
    "watch": "tsc -p tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\" *.mjs *.ts",
    "lint:fix": "eslint \"src/**/*.ts\" *.mjs *.ts --fix",
    "copy:files": "tsx ./src/scripts/build/copyTemplate.ts",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "report:view": "vite preview --outDir html",
    "docker:report:view": "vite preview --outDir html --host 0.0.0.0",
    "docker:test:ui": "vitest --ui --api.port 51204 --api.host 0.0.0.0",
    "docker:debug": "export IS_DOCKER=true && node --inspect=0.0.0.0:9229 --import tsx src/utils/sample.ts",
    "docker:dev:win": "export CHOKIDAR_USEPOLLING=1 && export CHOKIDAR_INTERVAL=1000 && vitest",
    "docker:watch:win": "tsc -p tsconfig.json --watch --watchFile dynamicPriorityPolling --watchDirectory dynamicPriorityPolling",
    "docker:test:ui:win": "export CHOKIDAR_USEPOLLING=1 && export CHOKIDAR_INTERVAL=1000 && npm run docker:test:ui",
    "sendemail": "node ./dist/scripts/cli/send.js",
    "sendemail:dev": "tsx ./src/scripts/cli/send.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weaponsforge/send-email.git"
  },
  "keywords": [
    "email",
    "smtp",
    "gmail",
    "cli",
    "send-email",
    "oauth2"
  ],
  "author": "weaponsforge",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/weaponsforge/send-email/issues"
  },
  "homepage": "https://github.com/weaponsforge/send-email#readme",
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ejs": "^4.0.1",
    "googleapis": "^171.4.0",
    "nodemailer": "^8.0.1",
    "sanitize-html": "^2.17.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^7.0.11",
    "@types/sanitize-html": "^2.16.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "execa": "^9.6.1",
    "globals": "^17.3.0",
    "postject": "^1.0.0-alpha.6",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
